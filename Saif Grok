<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>SAIF GROK - مولد فيديوهات AI</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css">
    <style>
        @import url('https://fonts.googleapis.com/css2?family=Cairo:wght@400;600;700&display=swap');
        
        body {
            font-family: 'Cairo', sans-serif;
        }
        
        .gradient-bg {
            background: linear-gradient(135deg, #0f172a 0%, #1e2937 100%);
        }
        
        .neon-button {
            transition: all 0.3s ease;
        }
        
        .neon-button:hover {
            transform: translateY(-3px);
            box-shadow: 0 0 25px rgba(59, 130, 246, 0.8);
        }
        
        .video-container {
            position: relative;
            border-radius: 16px;
            overflow: hidden;
            box-shadow: 0 25px 50px -12px rgb(0 0 0 / 0.4);
        }
        
        .generating {
            animation: pulse 2s infinite;
        }
    </style>
</head>
<body class="gradient-bg min-h-screen text-white">
    <div class="max-w-4xl mx-auto p-6">
        <!-- Header -->
        <div class="flex items-center justify-between mb-10">
            <div class="flex items-center gap-4">
                <div class="w-12 h-12 bg-blue-600 rounded-2xl flex items-center justify-center text-3xl font-bold">SG</div>
                <div>
                    <h1 class="text-4xl font-bold tracking-tight">SAIF GROK</h1>
                    <p class="text-blue-400 text-sm">مولد فيديوهات AI • مجاني 20 ثانية</p>
                </div>
            </div>
            <div class="flex items-center gap-3 text-sm">
                <div class="bg-green-500/20 text-green-400 px-4 py-2 rounded-full flex items-center gap-2">
                    <i class="fas fa-check-circle"></i>
                    <span>مجاني تماماً</span>
                </div>
                <div class="bg-slate-700 px-4 py-2 rounded-full">20 ثانية</div>
            </div>
        </div>

        <div class="grid grid-cols-1 lg:grid-cols-5 gap-8">
            <!-- Input Panel -->
            <div class="lg:col-span-2 bg-slate-900/70 backdrop-blur-xl rounded-3xl p-8 border border-slate-700">
                <h2 class="text-2xl font-semibold mb-6 flex items-center gap-3">
                    <i class="fas fa-magic text-blue-500"></i>
                    وصف الفيديو
                </h2>
                
                <textarea id="prompt" rows="6" 
                    class="w-full bg-slate-800 border border-slate-600 rounded-2xl p-5 text-lg focus:outline-none focus:border-blue-500 resize-none"
                    placeholder="اكتب وصف الفيديو بالتفصيل... مثال: قطة لطيفة تطير في سماء مدينة نيويورك عند الغروب"></textarea>
                
                <div class="mt-6 space-y-4">
                    <div>
                        <label class="block text-sm text-slate-400 mb-2">المدة</label>
                        <div class="bg-slate-800 rounded-2xl p-4 text-center font-medium border border-blue-500/30">
                            20 ثانية (مجاني)
                        </div>
                    </div>
                    
                    <div>
                        <label class="block text-sm text-slate-400 mb-2">الأسلوب</label>
                        <select id="style" class="w-full bg-slate-800 border border-slate-600 rounded-2xl p-4 focus:outline-none focus:border-blue-500">
                            <option value="realistic">واقعي (Cinematic)</option>
                            <option value="anime">أنمي</option>
                            <option value="cartoon">كرتون</option>
                            <option value="fantasy">فانتازيا</option>
                            <option value="abstract">تجريدي</option>
                        </select>
                    </div>
                </div>
                
                <button onclick="generateVideo()" 
                    id="generateBtn"
                    class="neon-button mt-8 w-full bg-blue-600 hover:bg-blue-500 py-6 rounded-3xl text-xl font-bold flex items-center justify-center gap-3 shadow-lg">
                    <i class="fas fa-bolt"></i>
                    توليد الفيديو (20 ثانية)
                </button>
                
                <p class="text-center text-xs text-slate-500 mt-6">
                    SAIF GROK • مدعوم بتقنية xAI
                </p>
            </div>
            
            <!-- Preview / Output -->
            <div class="lg:col-span-3">
                <div id="output" class="video-container bg-slate-950 aspect-video flex items-center justify-center border border-slate-700">
                    <!-- Initial State -->
                    <div id="initial-state" class="text-center">
                        <div class="w-24 h-24 mx-auto mb-6 bg-slate-800 rounded-3xl flex items-center justify-center text-5xl">
                            🎥
                        </div>
                        <h3 class="text-2xl font-medium mb-2">فيديو SAIF GROK</h3>
                        <p class="text-slate-400 max-w-xs mx-auto">اكتب وصفك واضغط على "توليد" لإنشاء فيديو مدته 20 ثانية</p>
                    </div>
                    
                    <!-- Loading State -->
                    <div id="loading-state" class="hidden flex-col items-center">
                        <div class="w-16 h-16 border-4 border-blue-500 border-t-transparent rounded-full animate-spin mb-6"></div>
                        <h3 class="text-xl font-medium mb-2">جاري التوليد...</h3>
                        <p class="text-slate-400 text-sm">SAIF GROK يعالج طلبك • 20 ثانية</p>
                        <div class="w-64 h-2 bg-slate-800 rounded-full mt-8 overflow-hidden">
                            <div id="progress" class="h-full bg-blue-500 w-0 transition-all duration-300"></div>
                        </div>
                    </div>
                    
                    <!-- Video Result -->
                    <div id="video-state" class="hidden w-full h-full relative">
                        <video id="generatedVideo" class="w-full h-full object-cover" controls loop>
                            <!-- يمكنك تغيير الرابط إلى فيديو تجريبي عام -->
                            <source src="https://assets.mixkit.co/videos/preview/754/754-large.mp4" type="video/mp4">
                            متصفحك لا يدعم تشغيل الفيديو.
                        </video>
                        <div class="absolute top-4 right-4 bg-black/70 px-3 py-1 rounded-full text-xs flex items-center gap-2">
                            <span class="text-green-400">✓</span>
                            20 ثانية
                        </div>
                        <div onclick="downloadVideo()" 
                            class="absolute bottom-4 left-4 bg-white/10 hover:bg-white/20 backdrop-blur px-5 py-2 rounded-2xl text-sm cursor-pointer flex items-center gap-2">
                            <i class="fas fa-download"></i>
                            تحميل
                        </div>
                    </div>
                </div>
                
                <div class="mt-6 flex justify-between items-center text-sm">
                    <div class="flex items-center gap-2 text-slate-400">
                        <i class="fas fa-info-circle"></i>
                        <span>الفيديو التجريبي (20 ثانية)</span>
                    </div>
                    <button onclick="resetInterface()" 
                        class="text-slate-400 hover:text-white flex items-center gap-2">
                        <i class="fas fa-redo"></i>
                        <span>توليد جديد</span>
                    </button>
                </div>
            </div>
        </div>
    </div>

    <script>
        function generateVideo() {
            const prompt = document.getElementById('prompt').value.trim();
            if (!prompt) {
                alert("يرجى كتابة وصف الفيديو أولاً!");
                return;
            }
            
            // Hide initial, show loading
            document.getElementById('initial-state').classList.add('hidden');
            document.getElementById('loading-state').classList.remove('hidden');
            document.getElementById('video-state').classList.add('hidden');
            
            const progressBar = document.getElementById('progress');
            let progress = 0;
            
            const interval = setInterval(() => {
                progress += Math.random() * 12;
                if (progress > 100) progress = 100;
                progressBar.style.width = `${progress}%`;
                
                if (progress >= 100) {
                    clearInterval(interval);
                    setTimeout(() => {
                        showVideoResult();
                    }, 600);
                }
            }, 180);
        }
        
        function showVideoResult() {
            document.getElementById('loading-state').classList.add('hidden');
            document.getElementById('video-state').classList.remove('hidden');
            
            // Auto play the video
            const video = document.getElementById('generatedVideo');
            video.play().catch(() => {});
        }
        
        function downloadVideo() {
            const video = document.getElementById('generatedVideo');
            const a = document.createElement('a');
            a.href = video.src || video.currentSrc;
            a.download = `saif_grok_video_${Date.now()}.mp4`;
            document.body.appendChild(a);
            a.click();
            document.body.removeChild(a);
            
            alert("تم بدء تحميل الفيديو (20 ثانية)");
        }
        
        function resetInterface() {
            document.getElementById('initial-state').classList.remove('hidden');
            document.getElementById('loading-state').classList.add('hidden');
            document.getElementById('video-state').classList.add('hidden');
            document.getElementById('progress').style.width = '0%';
        }
        
        // Tailwind script already included
        console.log('%cSAIF GROK Video Generator جاهز!', 'color: #3b82f6; font-size: 14px; font-weight: bold');
    </script>
</body>
</html>
